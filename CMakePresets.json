{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-msvc-vcpkg",
      "displayName": "Windows MSVC + vcpkg",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-msvc-vcpkg",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "linux-x64-vcpkg",
      "displayName": "Linux x64 + vcpkg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-x64-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "macos-arm64-vcpkg",
      "displayName": "macOS arm64 + vcpkg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-arm64-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    },
    {
      "name": "macos-x64-vcpkg",
      "displayName": "macOS x64 + vcpkg",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-x64-vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "x86_64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-osx"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-msvc-vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-msvc-vcpkg",
      "configuration": "Release"
    },
    {
      "name": "linux-x64-release",
      "configurePreset": "linux-x64-vcpkg"
    },
    {
      "name": "macos-arm64-release",
      "configurePreset": "macos-arm64-vcpkg"
    },
    {
      "name": "macos-x64-release",
      "configurePreset": "macos-x64-vcpkg"
    }
  ],
  "testPresets": [
    {
      "name": "windows-release-tests",
      "configurePreset": "windows-msvc-vcpkg",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-x64-tests",
      "configurePreset": "linux-x64-vcpkg",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-arm64-tests",
      "configurePreset": "macos-arm64-vcpkg",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-x64-tests",
      "configurePreset": "macos-x64-vcpkg",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
